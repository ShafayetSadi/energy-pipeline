# =============================================================================
# Edge Gateway configuration
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO
SERVICE_NAME=edge-gateway
SERVICE_VERSION=0.1.0

# =============================================================================
# MQTT broker
# =============================================================================
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=edge-gateway
MQTT_KEEPALIVE=60
MQTT_TELEMETRY_TOPIC=energy/+/telemetry
MQTT_STATUS_TOPIC=energy/+/status
MQTT_EVENTS_TOPIC=energy/+/events
MQTT_QOS_TELEMETRY=0
MQTT_QOS_STATUS=1
MQTT_QOS_EVENTS=1

# =============================================================================
# PostgreSQL / TimescaleDB
# =============================================================================
DATABASE_URL=postgresql+asyncpg://energy:energy@timescaledb:5432/energy_monitoring
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false
ENABLE_TIMESCALE=true

# =============================================================================
# Processing
# =============================================================================
# Mode: "baseline" (store every reading) or "proposed" (validate + rule engine + events)
PROCESSING_MODE=proposed
# Policy used in proposed mode: raw, hybrid, event_only, or aggregate_only.
STORAGE_POLICY=raw
STORE_RAW_READINGS=true
ENABLE_RULE_ENGINE=true
ENABLE_AGGREGATION=true
ENABLE_ALERTS=true

# =============================================================================
# Edge ML anomaly detection (Phase 1: Isolation Forest)
# =============================================================================
ENABLE_ML=false
ML_EMIT_EVENTS=false
# Score in an async micro-batch worker (off the ingestion hot path); set false
# to score inline per message (for the inline-vs-batched latency comparison).
ML_ASYNC_SCORING=true
ML_BATCH_MAX_SIZE=128
ML_BATCH_WINDOW_MS=50
ML_QUEUE_MAX_SIZE=20000
ML_MODEL_PATH=/app/models/anomaly_iforest.joblib
ML_MODEL_VERSION=iforest_v1
ML_FEATURES=voltage_v,current_a,power_w,temperature_c
# ML_SCORE_THRESHOLD=  # empty -> use threshold baked into the model artifact
ML_EVENT_TYPE=ML_ANOMALY
ML_EVENT_SEVERITY=WARNING

# =============================================================================
# Edge-to-cloud escalation (Phases 2-3)
# =============================================================================
# Mode: off, gated (anomalies only), or all (comparison baseline).
# Requires ENABLE_ML=true and ML_ASYNC_SCORING=true.
CLOUD_FORWARD_MODE=off
CLOUD_ENDPOINT_URL=http://cloud-tier:8000/api/v1/escalations
# CLOUD_ESCALATION_THRESHOLD=  # empty -> use the edge model threshold
CLOUD_FORWARD_BATCH_MAX_SIZE=64
CLOUD_FORWARD_BATCH_WINDOW_MS=1000
CLOUD_FORWARD_QUEUE_MAX_SIZE=20000
CLOUD_FORWARD_TIMEOUT_SECONDS=5

# =============================================================================
# Validation
# =============================================================================
VOLTAGE_MIN=0
VOLTAGE_MAX=300
CURRENT_MIN=0
CURRENT_MAX=100
POWER_MIN=0
POWER_MAX=20000
TEMPERATURE_MIN=-20
TEMPERATURE_MAX=100
MAX_FUTURE_SKEW_SECONDS=60
MAX_PAST_SKEW_SECONDS=86400
SUPPORTED_SCHEMA_VERSIONS=1.0

# =============================================================================
# Rule engine
# =============================================================================
RULES_FILE=/app/config/rules.yaml
ALERT_COOLDOWN_SECONDS=300
HEARTBEAT_TIMEOUT_SECONDS=30
HEARTBEAT_CHECK_INTERVAL_SECONDS=5

# =============================================================================
# Alerts
# =============================================================================
ALERT_WEBHOOK_URL=
ALERT_SLACK_WEBHOOK_URL=
ALERT_CONSOLE_ENABLED=true
ALERT_CRITICAL_ONLY=true
ALERT_OUTBOX_ENABLED=true
ALERT_OUTBOX_POLL_SECONDS=5
ALERT_OUTBOX_BATCH_SIZE=50
ALERT_OUTBOX_MAX_ATTEMPTS=5

# =============================================================================
# Data retention
# =============================================================================
RETENTION_ENABLED=true
RETENTION_RAW_READINGS_DAYS=30
RETENTION_QUALITY_LOGS_DAYS=14
RETENTION_SYSTEM_METRICS_DAYS=30
RETENTION_STATUS_HISTORY_DAYS=30
RETENTION_ALERT_DELIVERIES_DAYS=30
RETENTION_ALERT_OUTBOX_DAYS=30

# =============================================================================
# Metrics
# =============================================================================
METRICS_FLUSH_INTERVAL_SECONDS=10

{
  "uid": "event-timeline",
  "title": "Event Timeline",
  "tags": ["energy", "events"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Recent events",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT time, device_id, event_type, severity, rule_name, message FROM events WHERE time > now() - interval '6 hours' ORDER BY time DESC LIMIT 100"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Events by type (1m buckets)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__time(time), event_type, count(*) FROM events WHERE time > now() - interval '6 hours' GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Events by severity (1m buckets)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__time(time), severity, count(*) FROM events WHERE time > now() - interval '6 hours' GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    }
  ]
}

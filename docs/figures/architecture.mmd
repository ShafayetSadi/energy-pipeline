flowchart LR
    node["<b>STM32 node</b><br/>Nucleo-F429ZI firmware<br/><i>emulated in Renode</i>"]
    broker["<b>Mosquitto</b><br/>MQTT broker"]
    subgraph gw["FastAPI edge gateway — thesis contribution"]
        direction TB
        val["Payload validation<br/>schema · range · timestamp"]
        rules["Rule engine<br/>NORMAL / WARNING / CRITICAL"]
        ml["Isolation Forest<br/>anomaly score (edge)"]
        esc["Score-gated<br/>escalation"]
        val --> rules --> ml --> esc
    end
    db[("TimescaleDB<br/>readings · events")]
    cloud["<b>Cloud verifier</b><br/>LSTM-autoencoder<br/>on escalated stream"]
    graf["<b>Grafana</b><br/>dashboards · alerting"]

    node -- "MQTT · 1 Hz" --> broker
    broker --> gw
    gw --> db
    esc -. "flagged readings only" .-> cloud
    cloud -. "verified verdicts" .-> db
    db --> graf


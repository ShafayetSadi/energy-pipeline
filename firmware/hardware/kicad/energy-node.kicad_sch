  (label "PA1" (at 250.24 157.0 0) (fields_autoplaced) (effects (font (size 1.27 1.27)) (justify left bottom)) (uuid ecfa016c-d3ed-4b4f-98a6-6ccea365d22b))
  (rectangle (start 192 147) (end 270 162) (stroke (width 0.5) (type default)) (fill (type none)) (uuid 659db4fb-dd0e-44ba-bb4f-cb6315d63af2))
  (rectangle (start 196 150) (end 216 160) (stroke (width 0.4) (type default)) (fill (type none)) (uuid 24a1a978-8ffc-4e14-ab6e-9950eec92c15))
  (text "1. VOLTAGE SENSING CHANNEL" (at 25 30 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid cf3aec35-a4ae-4266-8135-7413e65d0bc7))
  (text "230 V AC -> galvanic isolation and scaling -> anti-alias filter -> PA0 voltage ADC" (at 25 34 0) (effects (font (size 1.6 1.6)) (justify left bottom)) (uuid 7aa07a3b-c771-4d91-b4a7-9b53659508a3))
  (text "R2 converts the isolated transformer current into a measurable voltage." (at 105 69 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid 349ae207-f69d-4522-8cbf-1bf2ac550556))
  (text "R5 + C2 form a 1.6 kHz low-pass filter before the STM32 ADC." (at 105 72 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid e3ea2353-c61c-454e-861f-b341e3bd561b))
  (text "SAFETY: J1 is mains voltage; use rated isolation, protection, and enclosure." (at 25 80 0) (effects (font (size 1.35 1.35) bold) (justify left bottom)) (uuid 2dcbc3fb-598f-46bf-898a-5c845f82f9b4))
  (text "2. CURRENT SENSING CHANNEL" (at 25 87 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid 13d7e58d-bf84-458b-b0f4-54ab3e121cf8))
  (text "SCT-013-030 clamp output -> internal burden -> anti-alias filter -> PA1 current ADC" (at 25 91 0) (effects (font (size 1.6 1.6)) (justify left bottom)) (uuid 398b6186-7a81-4427-b84c-098eb03869df))
  (text "R7 is the sensor's internal 66.7 ohm burden; do not add a second burden." (at 105 123 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid edbf8324-1920-4ffe-a900-c4383e3f5307))
  (text "R6 + C3 match the voltage-channel filter so phase error stays aligned." (at 105 126 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid 4a749831-137e-452d-ae4f-218ff0b0e33e))
  (text "3. SHARED ADC BIAS (MIDPOINT)" (at 25 137 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid e266c97e-8a63-4df1-a5c4-ce8059570daa))
  (text "R3 and R4 make 1.65 V; C1 stabilizes it. This shifts both AC waveforms into the 0-3.3 V ADC range." (at 25 141 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 8d80c585-bb71-4577-a062-4e67ab2cbc74))
  (text "V_BIAS = 1.65 V reference for both sensor channels" (at 105 163 0) (effects (font (size 1.35 1.35) bold) (justify left bottom)) (uuid f9ad3e12-e41f-442b-ae1f-4fd73079be01))
  (text "Power-flag symbols are KiCad checks for supplied 3V3/GND; they are not physical parts." (at 195 132 0) (effects (font (size 1.25 1.25)) (justify left bottom)) (uuid f8825bfc-f2af-4abb-8012-2b3030052c2b))
  (text "4. STM32 CONTROLLER INTERFACE" (at 195 137 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid abe9a470-e824-4fd5-9f32-3e11c9eb68e3))
  (text "NUCLEO-F429ZI development board with on-board STM32F429ZIT6 MCU" (at 195 141 0) (effects (font (size 1.5 1.5) bold) (justify left bottom)) (uuid a5522040-4ab9-45b5-bbf5-73197db46c1d))
  (text "Board-level abstraction: PA0 = voltage ADC; PA1 = current ADC." (at 195 145 0) (effects (font (size 1.25 1.25)) (justify left bottom)) (uuid a5342223-923f-4a91-8e50-6423cc0e44cf))
  (text "U1  STM32F429ZIT6" (at 198 153.5 0) (effects (font (size 1.5 1.5) bold) (justify left bottom)) (uuid b18acf80-7736-442b-90f5-60752e90af3a))
  (text "Arm Cortex-M4 MCU" (at 198 157 0) (effects (font (size 1.25 1.25)) (justify left bottom)) (uuid bc9c8c87-c205-495c-b791-d02eb54667a5))
  (text "on Nucleo-F429ZI board" (at 198 159.5 0) (effects (font (size 1.1 1.1)) (justify left bottom)) (uuid 4268a401-1b74-4806-a2dd-a0b0b30e45af))

  (label "PA1" (at 235.24 157.0 0) (fields_autoplaced) (effects (font (size 1.27 1.27)) (justify left bottom)) (uuid 9bd57b20-4cfb-4563-9928-1a4b2c011662))
  (text "1. VOLTAGE SENSING CHANNEL" (at 25 30 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid ee92b0b8-a442-4ca3-a3ca-2da486441183))
  (text "230 V AC -> galvanic isolation and scaling -> anti-alias filter -> PA0 voltage ADC" (at 25 34 0) (effects (font (size 1.6 1.6)) (justify left bottom)) (uuid 00b7e8d5-b115-4d3f-bf6a-dbdda3a48094))
  (text "R2 converts the isolated transformer current into a measurable voltage." (at 105 69 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid f6f2cd7c-38d2-4926-a7d4-fe6cedadc634))
  (text "R5 + C2 form a 1.6 kHz low-pass filter before the STM32 ADC." (at 105 72 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid ef601380-a85b-4e65-8937-62a6b7eed9d9))
  (text "SAFETY: J1 is mains voltage; use rated isolation, protection, and enclosure." (at 25 80 0) (effects (font (size 1.35 1.35) bold) (justify left bottom)) (uuid d72d7921-a8c7-4cb9-921b-baa698d5371b))
  (text "2. CURRENT SENSING CHANNEL" (at 25 87 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid 5e5ecead-8022-4b27-bbc0-748d6bd32549))
  (text "SCT-013-030 clamp output -> internal burden -> anti-alias filter -> PA1 current ADC" (at 25 91 0) (effects (font (size 1.6 1.6)) (justify left bottom)) (uuid 5a2dd336-dcec-4403-9097-d98140edd593))
  (text "R7 is the sensor's internal 66.7 ohm burden; do not add a second burden." (at 105 123 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid ace5ac99-b079-4532-bec3-4e69c9dbdd0b))
  (text "R6 + C3 match the voltage-channel filter so phase error stays aligned." (at 105 126 0) (effects (font (size 1.35 1.35)) (justify left bottom)) (uuid 9c39d3e4-bb54-438e-845c-e7cb1005543b))
  (text "3. SHARED ADC BIAS (MIDPOINT)" (at 25 137 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid 1fc98bdc-b01e-4a8a-b939-722e84c41971))
  (text "R3 and R4 make 1.65 V; C1 stabilizes it. This shifts both AC waveforms into the 0-3.3 V ADC range." (at 25 141 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 3ec53918-33b1-46ff-a099-f7a8ed617d4c))
  (text "V_BIAS = 1.65 V reference for both sensor channels" (at 105 163 0) (effects (font (size 1.35 1.35) bold) (justify left bottom)) (uuid fcd077fb-8cf8-46b4-873d-b8f5d9edbf9d))
  (text "Power-flag symbols are KiCad checks for supplied 3V3/GND; they are not physical parts." (at 195 132 0) (effects (font (size 1.25 1.25)) (justify left bottom)) (uuid 5eb63b64-ddfc-4efd-8ab9-69f6933035b5))
  (text "4. NUCLEO-F429ZI CONNECTIONS" (at 195 137 0) (effects (font (size 2.54 2.54) bold) (justify left bottom)) (uuid 54dcf24f-496b-41ba-a6d3-d0a084219de6))
  (text "PA0 = voltage samples; PA1 = current samples" (at 195 141 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 5fa51c22-7b14-43cb-9eb9-34893f44521d))
  (text "Matching net labels connect signals without long crossing wires." (at 195 145 0) (effects (font (size 1.25 1.25)) (justify left bottom)) (uuid 337bb868-90a8-474e-ac5a-a8909f67ac14))
